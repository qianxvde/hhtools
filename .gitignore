assets/motions/**/GVHMR/
!assets/motions/mimic/GVHMR/
!assets/motions/mimic/GVHMR/**
assets/motions/**/Humanoid-X/
!assets/motions/mimic/Humanoid-X/
!assets/motions/mimic/Humanoid-X/**
