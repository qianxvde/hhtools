# Robot presets: only ship the contributor template + Unitree G1 (URDF,
# meshes, robot.yaml, calibration).  Other presets and Web uploads live under
# ~/.config/hhtools/robots/ and stay untracked here.
configs/robots/*
!configs/robots/_template/
!configs/robots/_template/**
!configs/robots/unitree_g1/
!configs/robots/unitree_g1/**

# Large assets (use git-lfs if you need them tracked)
*.mp4
!docs/assets/videos/*.mp4
*.mov
*.avi

# Temp
tmp/
scratch/
*.log
